# Dependencias
node_modules/

# Base de datos (NO subir, tiene datos de canales)
# data/ — todo el contenido es runtime (DB, caches, backups, logos indexados)
data/*
!data/.gitkeep

# Media (muy pesado)
media/cache/
media/movies/
media/series/
media/subs/

# Logs
*.log
logs/

# Backups
*.bak
*.backup

# Variables de entorno (secretos)
.env
.env.local
.env.production
config.local.js

# Sistema operativo
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp

# Export temporal
export/
